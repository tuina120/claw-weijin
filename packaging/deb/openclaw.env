# OpenClaw runtime environment
# Edit this file after installation:
#   sudo nano /etc/openclaw/openclaw.env

PORT=4173
HOST=127.0.0.1
NODE_ENV=production

# Optional: expose files by public domain for generated links.
# OPENCLAW_FILES_PUBLIC_ORIGIN=https://file.example.com

# Optional: require login (0/1)
OPENCLAW_REQUIRE_LOGIN=0

# Data root
OPENCLAW_SHARE_DIR=/var/lib/openclaw/share

# Uploads (0 means unlimited per request; chunk upload is still recommended)
OPENCLAW_FILES_UPLOAD_MAX_BYTES=0

# Chunk upload behavior
OPENCLAW_FILES_CHUNK_BYTES=8388608
OPENCLAW_FILES_CHUNK_TTL_MS=86400000
